# htmldrill configuration — copy to .env and adjust. The wrapper auto-loads .env.

# Where per-target sidecars + blobs are written (default: ./drills)
# HTMLDRILL_WORK=drills

# Network fetch defaults (L0 `fetch`)
# HTMLDRILL_UA=htmldrill/0.1 (+https://github.com/WulfKolbe/htmldrill)
# HTMLDRILL_TIMEOUT=20
